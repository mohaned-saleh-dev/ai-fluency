# Google AI (Gemini)
GOOGLE_API_KEY=your_key_here
# or
# GEMINI_API_KEY=

# Default in code is gemini-2.5-flash. Lighter: gemini-2.5-flash-lite. See https://ai.google.dev/gemini-api/docs/models
# AIQ_GEMINI_MODEL=gemini-2.5-flash
# Set to 1 only if you want a second API call to classify paste vs heuristic only
# AIQ_LLM_CLASSIFY=0

# Second Gemini call to “repair” weak interviewer lines (truncated / praise-only). On Render,
# leave unset so it stays off (avoids ~100s proxy timeouts). Force on anywhere: AIQ_INTERVIEWER_REPAIR=1
# AIQ_INTERVIEWER_REPAIR=0

# LLM: auto (default) = Gemini if key set, else Ollama; or force gemini | ollama
# AIQ_LLM_PROVIDER=auto
# OLLAMA_BASE=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.2

# Long random string for /admin
AIQ_ADMIN_SECRET=replace_with_long_random
# Optional: multiple valid admin codes (comma/semicolon/newline separated)
# AIQ_ADMIN_SECRETS=alpha,beta,gamma

# DB path (optional)
# AIQ_SQLITE_PATH=/path/to/aiq_csuite.db

# Open sessions are auto-ended after this many hours (no new chat messages; scoring can still be requested).
# AIQ_SESSION_MAX_AGE_HOURS=24
